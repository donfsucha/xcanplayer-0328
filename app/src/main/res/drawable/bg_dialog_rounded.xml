<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".MainActivity">

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start|top"
        android:layout_marginTop="0dp"
        android:layout_marginStart="20dp"
        android:orientation="vertical"
        android:paddingVertical="10dp"
        android:paddingHorizontal="12dp"
        android:elevation="10dp"
        android:gravity="center_horizontal"
        android:background="@drawable/bg_black_panel">

        <ImageButton
            android:id="@+id/btnRotate"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/ic_rotate"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:tint="#FFFFFF"
            android:contentDescription="화면 회전" />

        <View android:layout_width="1dp" android:layout_height="30dp" />

        <TextView
            android:id="@+id/btnSpeed"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:background="@drawable/bg_circle_border"
            android:text="1.0x"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

        <View android:layout_width="1dp" android:layout_height="30dp" />

        <ImageButton
            android:id="@+id/btnSchedule"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:tint="#FFFFFF"
            android:contentDescription="스케줄 관리" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/fullscreen_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:elevation="20dp" />

</FrameLayout>